{#- Unified documentation snapshot template
    Rendered by HA template API at git sync time.
    Test by pasting into Developer Tools > Template.

    Produces sections for:
      README.md     — readme_snapshot (Key Metrics table)
      ARCHITECTURE.md — arch_header, arch_packages, arch_components,
                        arch_www_base, arch_www_cards, arch_pyscript,
                        arch_themes, arch_entity_counts, arch_ui_location
      CLAUDE.md     — claude_summary, claude_ha_version, claude_domain_table,
                        claude_ui_system

    Each section is delimited by <!-- section:NAME --> sentinels.
    git_sync.sh extracts and injects each block into its target file.
-#}
{#- ── Shared sensor aliases ────────────────────────────────────────────── -#}
{%- set edb = 'sensor.entity_domain_breakdown' -%}
{%- set dc  = 'sensor.dashboard_complexity' -%}
{%- set clb = 'sensor.config_line_breakdown' -%}
{%- set dbc = 'sensor.database_configuration' -%}
{%- set sdb = 'sensor.storage_directory_breakdown' -%}
{%- set pdb = 'sensor.package_domain_breakdown' -%}
{%- set fcb = 'sensor.frontend_code_breakdown' -%}

{#- ── Computed values (shared across sections) ─────────────────────────── -#}
{%- set core_ver = state_attr('update.home_assistant_core_update', 'installed_version') | default('?') -%}
{%- set os_ver = state_attr('update.home_assistant_operating_system_update', 'installed_version') | default('?') -%}
{%- set sup_ver = state_attr('update.home_assistant_supervisor_update', 'installed_version') | default('?') -%}
{%- set runtime = states(edb) | int(0) -%}
{%- set unavailable = state_attr(edb, 'unavailable') | int(0) -%}
{%- set unavailable_pct = ((unavailable / runtime * 100) | round(1)) if runtime > 0 else 0 -%}
{%- set custom_cc = states('sensor.custom_components_count') | int(0) -%}
{%- set config_lines = states(clb) | int(0) -%}
{%- set pkg_files = state_attr(pdb, 'total_files') | int(0) -%}
{%- set pkg_lines = states(pdb) | int(0) -%}
{%- set base_files = state_attr(fcb, 'base_files') | int(0) -%}
{%- set base_lines = state_attr(fcb, 'base_lines') | int(0) -%}
{%- set cards_files = state_attr(fcb, 'cards_files') | int(0) -%}
{%- set cards_lines = state_attr(fcb, 'cards_lines') | int(0) -%}
{%- set py_files = state_attr(fcb, 'pyscript_files') | int(0) -%}
{%- set py_lines = state_attr(fcb, 'pyscript_lines') | int(0) -%}
{%- set theme_lines = state_attr(fcb, 'themes_lines') | int(0) -%}
{%- set views = state_attr(dc, 'views') | int(0) -%}
{%- set total_cards = state_attr(dc, 'total_cards') | int(0) -%}
{%- set custom_cards = state_attr(dc, 'custom_cards') | int(0) -%}
{%- set standard_cards = state_attr(dc, 'standard_cards') | int(0) -%}
{%- set helpers = (state_attr(edb, 'input_booleans') | int(0)) + (state_attr(edb, 'input_numbers') | int(0)) + (state_attr(edb, 'input_selects') | int(0)) + (state_attr(edb, 'input_texts') | int(0)) + (state_attr(edb, 'input_datetimes') | int(0)) + (state_attr(edb, 'timers') | int(0)) + (state_attr(edb, 'counters') | int(0)) -%}

