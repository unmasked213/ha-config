{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/setup-env.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -S /var/run/supervisor.sock ] || [ -n \"$SUPERVISOR_TOKEN\" ]; then ha core check; fi"
          }
        ]
      }
    ]
  }
}
