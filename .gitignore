# --------------------------------------------
# Ignore folders - storage dashboards and whatsapp addon allowed
# --------------------------------------------
cloud/
.cursor/
.vscode/
.cloud/
.storage/
!.storage/lovelace.*
!.storage/lovelace_*
addons/*/
!addons/ha-addons/
!addons/ha-config-ai-agent/
!addons/whatsapp_addon/
custom_icons/
blueprints/
deps/
downloads/
image/
llmvision/
media/
tts/
uploads/

custom_components/
!custom_components/prompt_manager/
!custom_components/chatreader/
!custom_components/whatsapp_chat/
!custom_components/whatsapp/

docs/

# --------------------------------------------
# WWW rules — ignore subfolders except authored code
# --------------------------------------------
www/*/
www/*.csv
!www/base/
!www/cards/

# --------------------------------------------
# Ignore Python cache
# --------------------------------------------
__pycache__/
*.pyc

# --------------------------------------------
# Ignore specific file types (global)
# --------------------------------------------
*.tsx
*.txt
*.jpg
*.JPG
*.jpeg
*.JPEG
*.png
*.PNG
*.svg
*.mp4
*.avi
*.mov
*.mp3
*.wav
*.m4a
*.aac
*.ogg
*.flac


# --------------------------------------------
# Ignore anything with "backup" in the name
# --------------------------------------------
*backup*
*Backup*
*BACKUP*


# --------------------------------------------
# Ignore OS artifacts
# --------------------------------------------
.DS_Store
Thumbs.db

# --------------------------------------------
# Ignore runtime/generated files
# --------------------------------------------
.ha_run.lock
config_dir_tree.md
tracked_files.txt
tmp/
FAILURE_MODE_REPORT_*.md

